package admin

import (
	"fmt"
	"net/url"

	"github.com/milzamsz/go-pocket/components/layouts"
)

templ Dashboard(shell layouts.ShellState, stats DashboardStats) {
	@layouts.DashboardSurface(
		layouts.Meta{Title: "Admin Dashboard", Description: "Platform-level operations and health."},
		shell,
		"Platform Admin",
		"Admin Dashboard",
		"Platform-level operations and health.",
		adminSideNav("dashboard"),
		DashboardBody(stats),
	)
}

templ Users(shell layouts.ShellState, data UserListData) {
	@layouts.DashboardSurface(
		layouts.Meta{Title: "Users", Description: "Search and inspect user records."},
		shell,
		"Platform Admin",
		"Users",
		"Search and inspect user records.",
		adminSideNav("users"),
		UsersBody(data),
	)
}

templ UserDetail(shell layouts.ShellState, data UserDetailData) {
	@layouts.DashboardSurface(
		layouts.Meta{Title: "User Detail: " + data.ID, Description: "Detailed user profile and activity."},
		shell,
		"Platform Admin",
		"User Detail: "+data.ID,
		"Detailed user profile and activity.",
		adminSideNav("users"),
		UserDetailBody(data),
	)
}

