# APP_ENV: "development" (default) or "production"/"prod".
# In production, webhooks are rejected unless their *_WEBHOOK_SECRET is set
# (fail-closed), and missing secrets / non-HTTPS APP_BASE_URL are logged at boot.
APP_ENV=development
APP_URL=http://localhost:8090
APP_BASE_URL=http://localhost:8090
PORT=8090
LOG_LEVEL=info

PB_DATA_DIR=./pb_data

COOKIE_SECURE=false
SESSION_DOMAIN=localhost

RESEND_API_KEY=
RESEND_FROM=noreply@example.com

POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ORGANIZATION_ID=
POLAR_SUCCESS_URL=http://localhost:8090/org/{slug}/billing?success=1
POLAR_CANCEL_URL=http://localhost:8090/org/{slug}/billing?canceled=1

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
